{
    "name": "bf6-koth-mod",
    "experienceName": "KING OF THE HILL - CCL",
    "version": "1.5.66",
    "type": "module",
    "description": "Open-source King of the Hill mode for Battlefield 6 Portal by Enoc Bernal.",
    "engines": {
        "node": ">=24.0.0"
    },
    "scripts": {
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "build": "bf6-portal-bundler --entrypoint ./src/index.ts --outDir ./dist",
        "check:bundle:symbols": "node scripts/check-bundle-symbol-collisions.js",
        "check:bundle:stringkeys": "node scripts/check-bundle-stringkeys.js",
        "export-thumbnail": "node scripts/export-thumbnail.js",
        "minify-spatials": "node scripts/minify-all-spatials.js",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "prettier": "prettier --no-error-on-unmatched-pattern --write '**/*.{js,json,md,mjs,ts}'",
        "deploy": "npm run typecheck && npm run build && npm run -s check:bundle:symbols && node scripts/deploy.js --script dist/bundle.ts --strings dist/bundle.strings.json --versionBump patch",
        "deploy:patch": "npm run deploy",
        "deploy:minor": "npm run typecheck && npm run build && npm run -s check:bundle:symbols && node scripts/deploy.js --script dist/bundle.ts --strings dist/bundle.strings.json --versionBump minor",
        "deploy:major": "npm run typecheck && npm run build && npm run -s check:bundle:symbols && node scripts/deploy.js --script dist/bundle.ts --strings dist/bundle.strings.json --versionBump major"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mindflexor/bf6-koth-mod.git"
    },
    "keywords": [
        "battlefield-6",
        "bf6",
        "bf6-portal",
        "king-of-the-hill",
        "koth",
        "portal"
    ],
    "author": "Enoc Bernal",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/mindflexor/bf6-koth-mod/issues"
    },
    "homepage": "https://github.com/mindflexor/bf6-koth-mod#readme",
    "devDependencies": {
        "@eslint/js": "^10.0.0",
        "@bf6mods/portal": "^1.1.0",
        "bf6-portal-bundler": "^1.3.0",
        "bf6-portal-utils": "^8.0.0",
        "dotenv": "^17.3.1",
        "eslint": "^10.0.1",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.1",
        "quickjs-types": "^1.1.0",
        "sharp": "^0.34.5",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.0"
    },
    "main": "index.js",
    "directories": {
        "doc": "docs"
    }
}
