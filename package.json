{
    "name": "king-of-the-hill-mode-ccl-devkit",
    "experienceName": "KING OF THE HILL - CCL - [DEVKIT]",
    "version": "1.5.66",
    "type": "module",
    "description": "Open-source King of the Hill mode for Battlefield 6 Portal by Enoc Bernal.",
    "engines": {
        "node": ">=24.0.0"
    },
    "scripts": {
        "init": "node scripts/init.js",
        "update": "node scripts/update.js",
        "refresh-ai": "node scripts/generate-ai-context.js",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "build": "bf6-portal-bundler --entrypoint ./src/index.ts --outDir ./dist",
        "build:spectator": "bf6-portal-bundler --entrypoint ./src/index.with-spectator.ts --outDir ./dist",
        "check:bundle:symbols": "node scripts/check-bundle-symbol-collisions.js",
        "check:bundle:stringkeys": "node scripts/check-bundle-stringkeys.js",
        "export-thumbnail": "node scripts/export-thumbnail.js",
        "minify-spatials": "node scripts/minify-all-spatials.js",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "prettier": "prettier --no-error-on-unmatched-pattern --write '**/*.{js,json,md,mjs,ts}'",
        "deploy": "npm run typecheck && npm run build && npm run -s check:bundle:symbols && node scripts/deploy.js --script dist/bundle.ts --strings dist/bundle.strings.json --versionBump patch",
        "deploy:patch": "npm run deploy",
        "deploy:minor": "npm run typecheck && npm run build && npm run -s check:bundle:symbols && node scripts/deploy.js --script dist/bundle.ts --strings dist/bundle.strings.json --versionBump minor",
        "deploy:major": "npm run typecheck && npm run build && npm run -s check:bundle:symbols && node scripts/deploy.js --script dist/bundle.ts --strings dist/bundle.strings.json --versionBump major",
        "deploy:spectator": "npm run typecheck && npm run build:spectator && npm run -s check:bundle:symbols && node scripts/deploy.js --script dist/bundle.ts --strings dist/bundle.strings.json --versionBump patch",
        "deploy:spectator:minor": "npm run typecheck && npm run build:spectator && npm run -s check:bundle:symbols && node scripts/deploy.js --script dist/bundle.ts --strings dist/bundle.strings.json --versionBump minor",
        "deploy:spectator:major": "npm run typecheck && npm run build:spectator && npm run -s check:bundle:symbols && node scripts/deploy.js --script dist/bundle.ts --strings dist/bundle.strings.json --versionBump major"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mindflexor/bf6-squad-obliteration.git"
    },
    "keywords": [
        "template",
        "portal",
        "battlefield",
        "battlefield-6",
        "bf6"
    ],
    "author": "Enoc Bernal",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/mindflexor/bf6-squad-obliteration/issues"
